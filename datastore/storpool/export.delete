DRIVER_PATH="$(dirname "${0}")"

export LOG_PREFIX="ds"

# shellcheck source=tm/storpool/storpool_common.sh
source "${DRIVER_PATH}/../../tm/storpool/storpool_common.sh"

DST_HOST="$1"
FILE="$2"

splog "DST_HOST:${DST_HOST} FILE:${FILE}"

${SSH:-ssh} "${DST_HOST}" "test -L \"${FILE}\""
RET=$?
if [[ ${RET} -eq 0 ]]; then
    splog "${SSH} ${DST_HOST} test -L ${FILE} (${RET}) -- symlink"
    SP_VOLUME="${FILE##*/}"
    if kvGetUid "${SP_VOLUME}"; then
        storpoolDetach "${SP_UID}" "force" "${DST_HOST}"
        splog "Detach ${SP_UID} (${SP_VOLUME}) from ${DST_HOST} ($?)"
    else
        splog "[W] Can't get StorPool UID for ${SP_VOLUME}"
    fi
    storpoolDelete "${SP_UID}"  # TBD: check if this is correct? Should be in the above if and with exit on error?
else
    splog "${SSH:-ssh} ${DST_HOST} test -L ${FILE} (${RET}) -- not symlink"
    ${SSH:-ssh} "${DST_HOST}" "rm -f \"${FILE}\""
    splog "${SSH:-ssh} \"${DST_HOST}\" rm -f \"${FILE}\" ($?)"
fi
splog "END ${FILE}"
