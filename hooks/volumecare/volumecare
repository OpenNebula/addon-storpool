# shellcheck disable=SC2310

set -e

VMID="${1}"

export LOG_PREFIX="vc"
ONE_HOME="${ONE_HOME:-/var/lib/one}"
DRIVER_PATH="${ONE_HOME}/remotes/hooks/volumecare/"
cd "${DRIVER_PATH}"

# shellcheck source=tm/storpool/storpool_common.sh
source "${ONE_HOME}/remotes/tm/storpool/storpool_common.sh"
# shellcheck source=addon-storpoolrc
source "${ONE_HOME}/remotes/addon-storpoolrc"

boolTrue "DEBUG_alterVcPolicy" || export DEBUG_KV=""

if boolTrue "DDDEBUG_alterVcPolicy"; then
    parent="${PPID}"
    splog "[DDD] ${PWD}::${0} parent ${parent}::$(readlink -f "/proc/${parent}/exe"||true)::$(cat "/proc/${parent}/cmdline"||true)"
    echo "cd ${PWD} && ${0} $*" >"/tmp/VC_${VMID}.sh"
fi

# restrictive file permissions
umask -S u=rwx,g=rwx,o= >/dev/null

volumeListJson="${TMPDIR:-/tmp}/volumeList.json"
vmPoolFile="${TMPDIR:-/tmp}/vm_pool.xml"
dsPoolFile="${TMPDIR:-/tmp}/datastorePool.xml"
processedVolumes="${TMPDIR:-/tmp}/VMvolumes.txt"

declare -A DS_SP_API_HTTP_HOST  # DS_SP_API_HTTP_HOST[DATASTORE_ID] -> SP_API_HTTP_HOST
declare -A DS_SP_API_HTTP_PORT  # DS_SP_API_HTTP_PORT[DATASTORE_ID] -> SP_API_HTTP_PORT
declare -A DS_SP_AUTH_TOKEN     # DS_SP_AUTH_TOKEN[DATASTORE_ID] -> SP_AUTH_TOKEN

function update_volume_qc()
{
    local spName="$1" qc="$2" oldqc="$3" msg="$4"

    if [[ "${qc}" != "${oldqc}" ]]; then
        debug_sp_qosclass
        splog "${msg:+${msg} }volume ${spName} current qc:'${oldqc}' new:'${qc}'"
        storpoolVolumeTag "${spName}" "qc" "${qc}"
    else
        if boolTrue "DDEBUG_alterVcPolicy"; then
            splog "${msg:+${msg} }volume ${spName} current qc:'${qc}'"
        fi
    fi
}

function update_volume_vc_policy()
{
    local spName="$1" vcp="$2" oldvcp="$3" msg="$4"

    if [[ "${vcp}" != "${oldvcp}" ]]; then
        splog "${msg:+${msg} }volume ${spName} current vc-policy:'${oldvcp}' new:'${vcp}'"
        storpoolVolumeTag "${spName}" "vc-policy" "${vcp}"
    else
        if boolTrue "DDEBUG_alterVcPolicy"; then
            splog "${msg:+${msg} }volume ${spName} current vc-policy:'${vcp}'"
        fi
    fi
}

function alterVcPolicy()
{
    local vmId="$1"
    local volumeListJsonFile="" xfh=""

    if [[ -z "${vmId}" ]]; then
        oneCallXml onevm list --extended "${vmPoolFile}"
        if [[ ${ret} -ne 0 ]]; then
            splog "Error! Can't get VM list!"
            while read -r -u 4 err; do
                splog "Err: ${err}"
            done 4< <(cat "${TMPDIR:-/tmp}/vm_pool.errlog" || true)
            return 1
        fi
        while read -r -u "${xfh}" _vmId; do
            alterVcPolicy "${_vmId}"
        done {xfh}< <(${XMLSTARLET:-xmlstarlet} sel -t -m "/VM_POOL/VM" -v 'ID' -n "${vmPoolFile}" || true)
        exec {xfh}<&-
        return 0
    fi

    if boolTrue "DDEBUG_alterVcPolicy"; then
        splog "alterVcPolicy(${vmId}, ${vmPoolFile})"
    fi

    unset SP_QOSCLASS
    oneVmVolumes "${vmId}" "${vmPoolFile}"

    if [[ -z "${vmDisksMap}" ]]; then
        if boolTrue "DDEBUG_alterVcPolicy"; then
            splog "alterVcPolicy(${vmId},${vmPoolFile}) vmDisksMap is empty. Return 0"
        fi
        return 0
    fi

    if [[ -n "${VM_DS_ID}" ]]; then
        oneDatastoreInfo "${VM_DS_ID}" "${dsPoolFile}"
        SYSTEM_DS_SP_QOSCLASS="${DS_SP_QOSCLASS}"
        DS_SP_API_HTTP_HOST["${VM_DS_ID}"]="${SP_API_HTTP_HOST}"
        DS_SP_API_HTTP_PORT["${VM_DS_ID}"]="${SP_API_HTTP_PORT}"
        DS_SP_AUTH_TOKEN["${VM_DS_ID}"]="${SP_AUTH_TOKEN}"
    else
        if boolTrue "DDEBUG_alterVcPolicy"; then
            splog "[DD][alterVcPolicy] VM ${vmId} VM_DS_ID is empty. Return 0"
        fi
        return 0
    fi

    if boolTrue "DDEBUG_alterVcPolicy"; then
        _DBGMSG="[alterVcPolicy] VM ${vmId}"
        _DBGMSG+=" VM_SP_QOSCLASS:${VM_SP_QOSCLASS}"
        _DBGMSG+=" SYSTEM_DS_SP_QOSCLASS:${SYSTEM_DS_SP_QOSCLASS}"
        _DBGMSG+=" DEFAULT_QOSCLASS:${DEFAULT_QOSCLASS}"
        _DBGMSG+=" VM_DS_ID:${VM_DS_ID}"
        _DBGMSG+=" DS_SP_API_HTTP_HOST:${DS_SP_API_HTTP_HOST[${VM_DS_ID}]}"
        _DBGMSG+=" DS_SP_API_HTTP_PORT:${DS_SP_API_HTTP_PORT[${VM_DS_ID}]}"
        _DBGMSG+=" DS_SP_AUTH_TOKEN:${DS_SP_AUTH_TOKEN[${VM_DS_ID}]:+AVAILABLE}"
        splog "[DD]${_DBGMSG}"
    fi
    debug_sp_qosclass

    unset diskNames_a uidsDiskid_a volUids_a
    declare -gA diskNames_a  # diskNames_a[DISK_ID]=oneName
    declare -gA uidsDiskid_a # uidsDiskid_a[SP_UID]=oneName
    declare -gA volUidName_a # volUidName_a[SP_UID]=oneName
    declare -gA volUids_a  # volUids_a[oneName]=SP_UID
    # vmDisksMap: 'oneName:DISK_ID ...'
    for disk in ${vmDisksMap}; do
        oneName="${disk%:*}"
        disk_id="${disk#*:}"
        diskNames_a["disk${disk_id}"]="${oneName}"
        if kvGetUid "${oneName}"; then
            uidsDiskid_a["${SP_UID}"]="${disk_id}"
            volUidName_a["${SP_UID}"]="${oneName}"
            volUids_a["${oneName}"]="${SP_UID}"
        else
            splog "Can't get SP UID for volume '${oneName}' disk_id:${disk_id} disk:${disk} //PATH=${PATH}"
        fi
    done
    export diskNames_a uidsDiskid_a volUids_a volUidName_a

    unset diskType_a
    declare -A diskType_a  # diskType_a[oneName]=DISK_TYPE
    for entry in ${vmDisksTypeMap}; do
        diskType_a["${entry%%:*}"]="${entry#*:}"  # diskType_a[oneName]=DISK_TYPE
    done

    unset volumesQc_a
    declare -A volumesQc_a  # volumesQc_a[oneName]=QosClassName
    # vmDisksQcMap: 'oneName:VM_DISK_QOSCLASS ...'
    for entry in ${vmDisksQcMap}; do
        volumesQc_a["${entry%%:*}"]="${entry#*:}"  # volumesQc_a[oneName]=VM_DISK_QOSCLASS
    done

    declare -A persistentDisksQc_a  # persistentDisksQc_a[oneName]=QOSCLASS
    for vol in ${persistentDisksQcMap}; do
        persistentDisksQc_a["${vol%%:*}"]="${vol#*:}"  # [oneName]=QOSCLASS
    done

    declare -A volumesDsId_a  # volumesDsId_a[oneName]=DATASTORE_ID
    # vmDisksDsMap: 'oneName:DATASTORE_ID ...'
    for entry in ${vmDisksDsMap}; do
        oneName="${entry%%:*}"
        dsId="${entry#*:}"
        if [[ -z "${datastoresQc_a[${dsId}]}" ]]; then
            oneDatastoreInfo "${dsId}" "${dsPoolFile}"
            datastoresQc_a["${dsId}"]="${DS_SP_QOSCLASS}"  # [DATASTORE_ID]=DS_SP_QOSCLASS
        fi
        volumesDsId_a["${oneName}"]="${dsId}"  # [oneName]=DATASTORE_ID
    done
    if boolTrue "DEBUG_alterVcPolicy"; then
        splog "[D] VM ${vmId} VC_POLICY:'${VC_POLICY}' vmDisksMap='${vmDisksMap}'"
        splog "[D] VM ${vmId} VM_SP_QOSCLASS='${VM_SP_QOSCLASS}' disks_qc:[${!volumesQc_a[*]}:${volumesQc_a[*]}] persistent_disks_qc:[${!persistentDisksQc_a[*]}:${persistentDisksQc_a[*]}]"
    else
        export DEBUG_SP_RUN_CMD=""
    fi

    if [[ ! -f "${volumesListJson}" ]]; then
        DO_MULTICLUSTER=1 DO_ALLCLUSTERS=1 storpoolRetry VolumesList
        volumesListJson="${TMPDIR:-/tmp}/VolumesList.json"
        if boolTrue "DDDEBUG_alterVcPolicy"; then
            cp "${volumesListJson}" "/tmp/DEBUG_alterVcPolicy-VolumesList.json" 2>/dev/null
        fi
    fi

    while read -r -u "${xfh}" _line; do
        IFS=';' read -ra spdata <<<"${_line}"
        spname="${spdata[0]//:/}"
        tagVc="${spdata[1]#null}"
        tagQc="${spdata[2]#null}"
        tagImg="${spdata[3]#null}"
        if [[ -n "${uidsDiskid_a[${spname}]+found}" ]]; then
            oneName="${volUidName_a[${spname}]}"
            # vc-policy tag update
            tagVcNew="${VC_POLICY//[[:space:]]/}"
            update_volume_vc_policy "${spname}" "${tagVcNew}" "${tagVc}" "VM ${vmId} DISK ${uidsDiskid_a[${spname}]} ${oneName}"

            # qc tag update
            IMAGE_SP_QOSCLASS="${persistentDisksQc_a[${oneName}]}"
            SYSTEM_DS_SP_QOSCLASS="${datastoresQc_a[${VM_DS_ID}]}"
            unset IMAGE_DS_SP_QOSCLASS
            if [[ -n "${volumesDsId_a[${oneName}]}" ]]; then
                IMAGE_DS_SP_QOSCLASS="${datastoresQc_a[${volumesDsId_a[${oneName}]}]}"
            fi
            VM_DISK_SP_QOSCLASS="${volumesQc_a[${oneName}]}"
            # shellcheck disable=SC2078
            case "${diskType_a[${oneName}]^^}" in
                PERS*|IMM*)
                    if [[ -n "${IMAGE_SP_QOSCLASS}" ]]; then
                        IMAGE_DS_SP_QOSCLASS=""
                        SYSTEM_DS_SP_QOSCLASS=""
                        VM_SP_QOSCLASS=""
                    fi
                    ;;
                *)
                    : # no-op
                    ;;
            esac
            if [[ -n "${VM_DISK_SP_QOSCLASS}" ]]; then  # explicit vm disk qosclass
                tagQcNew="${VM_DISK_SP_QOSCLASS}"
                used="VM_DISK_SP_QOSCLASS"
            elif [[ -n "${IMAGE_SP_QOSCLASS}" ]]; then  # persistent image qosclass
                tagQcNew="${IMAGE_SP_QOSCLASS}"
                used="IMAGE_SP_QOSCLASS"
            elif [[ -n "${VM_SP_QOSCLASS}" ]]; then  # vm qosclass
                tagQcNew="${VM_SP_QOSCLASS}"
                used="VM_SP_QOSCLASS"
            elif [[ -n "${SYSTEM_DS_SP_QOSCLASS}" ]]; then  # system ds qosclass
                tagQcNew="${SYSTEM_DS_SP_QOSCLASS}"
                used="SYSTEM_DS_SP_QOSCLASS"
            elif [[ -n "${IMAGE_DS_SP_QOSCLASS}" ]]; then  # image ds qosclass
                tagQcNew="${IMAGE_DS_SP_QOSCLASS}"
                used="IMAGE_DS_SP_QOSCLASS"
            else  # default qosclass
                tagQcNew="${DEFAULT_QOSCLASS}"
                used="DEFAULT_QOSCLASS"
            fi
            update_volume_qc "${spname}" "${tagQcNew}" "${tagQc}" "VM ${vmId} DISK ${uidsDiskid_a[${spname}]} (${used})"
            echo "${spname}" >>"${processedVolumes}"
        fi
    done {xfh}< <(jq -r '.data.clusters[]|.response.data[]|"\(.name);\(.tags["vc-policy"]|tostring);\(.tags["qc"]|tostring);\(.tags["img"]|tostring)"' "${volumesListJson}" || true)
    exec {xfh}<&-
    unset vmVolumesvmDisksMap vmDisksQcMap vmDisksDsMap persistentDisksQcMap
}

function alterImagesQosClass()
{
    local xfh=""
    declare -A dsQosClass_a
    volumeListJsonFile=""

    if [[ ! -f "${dsPoolFile}" ]]; then
        oneCallXml oneDatastore list "" "${dsPoolFile}"
    fi

    while read -r -u "${xfh}" dsId dsQosClass; do
        dsQosClass_a["${dsId}"]="${dsQosClass}"  # dsQosClass_a[DATASTORE_ID]=QOSCLASS
    done {xfh}< <(xmlstarlet sel -t \
        -m "/DATASTORE_POOL/DATASTORE" \
        -v 'ID' \
        -o ' ' -v "TEMPLATE/SP_QOSCLASS" \
        -n "${dsPoolFile}" || true)
    exec {xfh}<&-

    imagePoolFile="${TMPDIR}/imagePool.xml"
    if [[ ! -f "${imagePoolFile}" ]]; then
        oneCallXml oneimage list "" "${imagePoolFile}"
    fi

    declare -A imagesQosClass_a  # imagesQosClass_a[oneName]=QOSCLASS
    while read -r -u "${xfh}" imageline; do
        [[ "${imageline:0:3}" == "img" ]] || continue
        IFS=';' read -r -a imgData <<<"${imageline}"
        image_id="${imgData[1]}"
        image_ds_id="${imgData[2]}"
        # persistent="${imgData[3]}"
        imgQosClass="${imgData[4]}"
        imgVms="${imgData[5]}"
        # skip Images attached to VMs
        [[ -z "${imgVms}" ]] || continue
        oneName="${ONE_PX:-one}-img-${image_id}"
        imagesQosClass_a["${oneName}"]="${imgQosClass:-${dsQosClass_a[${image_ds_id}]:-${DEFAULT_QOSCLASS}}}"
    done {xfh}< <(xmlstarlet sel -t \
        -m "/IMAGE_POOL/IMAGE" \
        -o 'img;' -v 'ID' \
        -o ';' -v "DATASTORE_ID" \
        -o ';' -v PERSISTENT \
        -o ';' -v "TEMPLATE/SP_QOSCLASS" \
        -o ';' -v "VMS/ID" \
        -n "${imagePoolFile}" || true)
    exec {xfh}<&-

    if [[ ! -f ${volumesListJson} ]]; then
        DO_MULTICLUSTER=1 DO_ALLCLUSTERS=1 storpoolRetry VolumesList
        volumesListJson="${TMPDIR:-/tmp}/VolumesList.json"
        if boolTrue "DDDEBUG_alterVcPolicy"; then
            cp "${volumesListJson}" "/tmp/DEBUG_alterVcPolicy-VolumesList.json" 2>/dev/null
        fi
    fi
    if boolTrue "DDDDEBUG_alterVcPolicy"; then
        splog "[DDDD]alterImagesQosClass() imagesQosClass_a:${!imagesQosClass_a[*]}=${imagesQosClass_a[*]}"
    fi
    for ds_id in "${!DS_SP_API_HTTP_HOST[@]}"; do
        if [[ -n "${DS_SP_AUTH_TOKEN[${ds_id}]}" ]]; then
            export SP_AUTH_TOKEN="${DS_SP_AUTH_TOKEN[${ds_id}]}"
        else
            unset SP_AUTH_TOKEN
        fi
        if [[ -n "${DS_SP_API_HTTP_HOST[${ds_id}]}" ]]; then
            export SP_API_HTTP_HOST="${DS_SP_API_HTTP_HOST[${ds_id}]}"
        else
            unset SP_API_HTTP_HOST
        fi
        if [[ -n "${DS_SP_API_HTTP_PORT[${ds_id}]}" ]]; then
            export SP_API_HTTP_PORT="${DS_SP_API_HTTP_PORT[${ds_id}]}"
        else
            unset SP_API_HTTP_PORT
        fi
        volumeListJsonFile="${volumeListJson}-${SP_API_HTTP_HOST:-0.0.0.0}"
        if [[ ! -f "${volumeListJsonFile}" ]]; then
            DO_MULTICLUSTER=1 DO_ALLCLUSTERS=1 storpoolRetry VolumesList
            volumesListJson="${TMPDIR:-/tmp}/VolumesList.json"
            if boolTrue "DDDEBUG_alterVcPolicy"; then
                cp "${volumesListJson}" "${volumeListJsonFile}" 2>/dev/null
            fi

        fi

        while read -r -u "${xfh}" _line; do
            IFS=\; read -ra spdata <<<"${_line}"
            spname="${spdata[0]}"
            tagQc="${spdata[1]#null}"
            tagImg="${spdata[2]#null}"
            img_id="${tagImg##*-}"
            if [[ -n "${imagesQosClass_a[${spname}]+found}" ]]; then
                if grep -Eqe "^${spname}$" "${TMPDIR:-/tmp}/VMvolumes.txt" &>/dev/null; then
                    if boolTrue "DDDEBUG_alterVcPolicy"; then
                        splog "[DDD] IMG ${img_id} img ${tagImg} spname ${spname} already processed"
                    fi
                    continue
                fi
                tagQcNew="${imagesQosClass_a[${spname}]}"
                update_volume_qc "${spname}" "${tagQcNew}" "${tagQc}" "IMG ${img_id}"
            fi
        done {xfh}< <(jq -r '.data.clusters[]|.response.data[]|"\(.name);\(.tags["qc"]|tostring);\(.tags["img"]|tostring)"' "${volumesListJson}" || true)
        exec {xfh}<&-
    done
}


if [[ -n ${VMID} ]]; then
    alterVcPolicy "${VMID}"
else
    # try detecting RAFT_LEADER_IP from opennebula's config
    if [[ -z ${RAFT_LEADER_IP} ]] && [[ -f "${ONE_HOME}/config" ]]; then
        #RAFT_LEADER_HOOK=ARGUMENTS=leader vlan11 10.163.1.250,COMMAND=raft/vip.sh
        RAFT_IP="$(awk '$0 ~ /^RAFT_LEADER_HOOK/{print $3}' "${ONE_HOME}/config" | tail -n 1 || true)"
        if [[ -n "${RAFT_IP}" ]]; then
            RAFT_LEADER_IP="${RAFT_IP%%/*}"
            RAFT_LEADER_IP="${RAFT_LEADER_IP%%,*}"
        fi
    fi
    if [[ -n "${RAFT_LEADER_IP#disabled}" ]]; then
        tmp="$(ip route get "${RAFT_LEADER_IP}" 2>/dev/null | head -n 1 || true)"
        if [[ "${tmp:0:5}" == "local" ]]; then
            if boolTrue "DDEBUG_alterVcPolicy"; then
                splog "[DD] Found leader IP (${RAFT_LEADER_IP})."
            fi
        else
            if boolTrue "DDEBUG_alterVcPolicy"; then
                splog "[DD] There is no leader IP found (${RAFT_LEADER_IP}). Exit."
            fi
            exit 0
        fi
    fi
    # walk all VMs
    alterVcPolicy
    # walk all images
    alterImagesQosClass
fi
