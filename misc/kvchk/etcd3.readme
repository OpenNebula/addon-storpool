# list all "live" endpoints
etcdctl --endpoints=NODE1_IP:2379,NODE2_IP:2379,...  member remove xxxxxxxxxxxxxxxx
# add the new peer to the cluster
etcdctl member add PEER_HOSTNAME --peer-urls=http://192.168.11.61:2380
