#-------------------------------------------------------------------------------
# delete host:remote_system_ds/disk.i vmId datastoreId
#-------------------------------------------------------------------------------

#-------------------------------------------------------------------------------
# Get delete arguments from OpenNebula core
#-------------------------------------------------------------------------------

DST="$1"
VM_ID="$2"
DS_ID="$3"

TM_PATH="$(dirname "$0")"
# shellcheck source=tm/storpool/storpool_common.sh
source "${TM_PATH}/storpool_common.sh"

splog "DST=${DST} VM_ID=${VM_ID} DS_ID=${DS_ID}"

#-------------------------------------------------------------------------------
# Process destination
#-------------------------------------------------------------------------------

DST_PATH="$(arg_path "${DST}")"
DST_HOST="$(arg_host "${DST}")"
# shellcheck disable=SC2016
DISK_ID="$(echo "${DST_PATH}" | ${AWK:-awk} -F. '{print $NF}' || true)"
IS_DISK="$(is_disk "${DST_PATH}")"

#-------------------------------------------------------------------------------
# Get Datastore information
#-------------------------------------------------------------------------------

oneDatastoreInfo "${DS_ID}"

if boolTrue "IS_DISK"; then
    oneVmInfo "${VM_ID}" "${DISK_ID}"
    SP_VOL="${SOURCE##*/}"
    if [[ -z ${SP_VOL} ]]; then
        SP_VOL="${ONE_PX}-sys-${VM_ID}-${DISK_ID}"
    fi
fi

if [[ "${DS_TEMPLATE_TYPE}" == "SYSTEM_DS" ]]; then
    TEMPLATE=""
    oneTemplateInfo "${TEMPLATE}" #TBD
    LCM_STATE="${VM_LCM_STATE}"
    for i in "${!DISK_ID_ARRAY[@]}"; do
        if [[ -z "${DISK_TM_MAD_ARRAY[i]}" ]]; then
#            splog "[SYSTEM_DS] $i id:${DISK_ID_ARRAY[i]} type:${DISK_TYPE_ARRAY[i]} format:$FORMAT tm:${DISK_TM_MAD_ARRAY[i]}"
            if [[ "${IS_DISK}" == 1 ]]; then
                if [[ "${DISK_ID_ARRAY[i]}" != "${DISK_ID}" ]]; then
#                    splog "[SYSTEM_DS] skip ${DISK_ID_ARRAY[i]} != $DISK_ID"
                    continue
                fi
            fi
            SP_VOL="${ONE_PX}-sys-${VM_ID}-${DISK_ID_ARRAY[i]}"
            if kvGetUid "${SP_VOL}"; then
                VOL_UID="${SP_UID}"
                storpoolDelete "${VOL_UID}" "force" "snaps" "${REMOTE_BACKUP_DELETE}" "\"img\":\"${SP_VOL}\",\"reason\":\"tm_delete\""
                if boolTrue "VMSNAPSHOT_DELETE_ON_TERMINATE"; then
                    if [[ ${LCM_STATE} -ne 15 ]]; then
                        # Combined deletion: both regular "snap" and VM "ONESNAP" snapshots
                        storpoolSnapshotsDelete "${SP_VOL}" "snap,${VMSNAPSHOT_TAG}"
                    else
                        splog "VMSNAPSHOT ${SP_VOL}-${VMSNAPSHOT_TAG}-* not deleted LCM_STATE=${LCM_STATE}"
                    fi
                fi
            fi
            RM_CMD="rm -rf '${DST_PATH}/disk.${DISK_ID_ARRAY[i]}'"
            splog "run RM_CMD on ${DST_HOST} (${DST_PATH}/disk.${DISK_ID_ARRAY[i]})"
            ssh_exec_and_log "${DST_HOST}" "${RM_CMD}" \
                "Error deleting ${DST_PATH}/disk.${DISK_ID_ARRAY[i]} on ${DST_HOST}"
#        else
#            splog "[SYSTEM_DS] SKIP $i type:${DISK_TYPE_ARRAY[i]} format:${DISK_FORMAT_ARRAY[i]:-raw} tm:${DISK_TM_MAD_ARRAY[i]}"
        fi
    done

    if boolTrue "IS_DISK"; then
        for VOL_UID in $(storpoolVolumeStartswith "${SP_VOL}"); do
            storpoolDelete "${VOL_UID}" "force" "" "${REMOTE_BACKUP_DELETE}" "\"img\":\"${SP_VOL}\",\"reason\":\"tm_delete\""
            if boolTrue "VMSNAPSHOT_DELETE_ON_TERMINATE"; then
                if [[ ${LCM_STATE} -ne 15 ]]; then
                    # Combined deletion: both regular "snap" and VM "ONESNAP" snapshots
                    storpoolSnapshotsDelete "${SP_VOL}" "snap,${VMSNAPSHOT_TAG}"
                else
                    splog "VMSNAPSHOT(s) not edeleted because LCM_STATE=${LCM_STATE} (${SP_VOL}-${VMSNAPSHOT_TAG}-*)"
                fi
            fi
        done
    else
        # TPM volume
        if boolTrue "ONE_TPM_SAVE"; then
            splog "VM ${VM_ID} TPM_MODEL=${TPM_MODEL}"
            if [[ -n "${TPM_MODEL}" ]]; then
                SP_VOL="${ONE_PX}-sys-${VM_ID}-SWTPM"
                if kvGetUid "${SP_VOL}"; then
                    VOL_UID="${SP_UID}"
                    storpoolDelete "${VOL_UID}" "force" "snaps" "" "\"img\":\"${SP_VOL}\",\"reason\":\"tm_delete\""
                fi
            fi
        fi
        DELAY_DELETE=
        if [[ -n "${CONTEXT_DISK_ID}" ]]; then
            SP_VOL="${ONE_PX}-sys-${VM_ID}-${CONTEXT_DISK_ID}"
            if kvGetUid "${SP_VOL}"; then
                VOL_UID="${SP_UID}"
                storpoolDelete "${VOL_UID}" "force" "snaps" "" "\"img\":\"${SP_VOL}\""
                if boolTrue "VMSNAPSHOT_DELETE_ON_TERMINATE"; then
                    if [[ ${LCM_STATE} -ne 15 ]]; then
                        # Combined deletion: both regular "snap" and VM "ONESNAP" snapshots
                        storpoolSnapshotsDelete "${SP_VOL}" "snap,${VMSNAPSHOT_TAG}"
                    else
                        splog "VMSNAPSHOT ${SP_VOL}-${VMSNAPSHOT_TAG}* not deleted LCM_STATE=${LCM_STATE}"
                    fi
                fi
            fi
        fi
        if boolTrue "SP_CHECKPOINT_BD"; then
            SP_VOL="${ONE_PX}-sys-${VM_ID}-rawcheckpoint"
            if kvGetUid "${SP_VOL}"; then
                storpoolDelete "${SP_UID}" "force" "" "" "\"sys\":\"${SP_VOL}\",\"reason\":\"tm_delete\""
            fi
        fi
        if [[ -n "${T_OS_NVRAM}" ]]; then
            SP_VOL="${ONE_PX}-sys-${VM_ID}-NVRAM"
            if kvGetUid "${SP_VOL}"; then
                VOL_UID="${SP_UID}"
                storpoolDelete "${VOL_UID}" "force" "snaps" "${REMOTE_BACKUP_DELETE}" "\"sys\":\"${SP_VOL}\",\"reason\":\"tm_delete\""
                if boolTrue "VMSNAPSHOT_DELETE_ON_TERMINATE"; then
                    if [[ ${LCM_STATE} -ne 15 ]]; then
                        storpoolSnapshotsDelete "${SP_VOL}" "${VMSNAPSHOT_TAG}"
                    else
                        splog "VMSNAPSHOT ${SP_VOL}-${VMSNAPSHOT_TAG}-* not deleted LCM_STATE=${LCM_STATE}"
                    fi
                fi
            fi
        fi
    fi
    RM_CMD="rm -rf '${DST_PATH}'"
    if hostReachable "${DST_HOST}"; then
        splog "run RM_CMD on ${DST_HOST} (${DST_PATH})"
        ssh_exec_and_log "${DST_HOST}" "${RM_CMD}" \
              "Error deleting ${SP_VOL} in ${DST_HOST}(${DST_PATH})"
    else
        splog "Host unreachable: ${DST_HOST}, skipping ${RM_CMD}"
    fi

    splog "END ${VM_ID} [SYSTEM_DS]"
    exit 0
fi

oneVmInfo "${VM_ID}" "${DISK_ID}"

IMMUTABLE="$(isImmutable "${CLONE}" "${SAVE}" "${READONLY}")"

if boolTrue "CLONE"; then
    SP_VOL+="-${VM_ID}-${DISK_ID}"
    if kvGetUid "${SP_VOL}"; then
        VOL_UID="${SP_UID}"
        log "Deleting ${DST_PATH} ${VOL_UID} (${SP_VOL})"
        storpoolDelete "${VOL_UID}" "force" "snaps" "${REMOTE_BACKUP_DELETE}" "\"img\":\"${SP_VOL}\",\"reason\":\"tm_delete\""
    fi
elif boolTrue "IMMUTABLE" "${IMMUTABLE}"; then
    if [[ "${TYPE}" == "CDROM" ]]; then
        # DISK/TYPE="CDROM"
        # backward compatibility
        if boolTrue "CDROM_BACKWARD_COMPATIBILITY"; then #TBD
            if kvGetUid "${SP_VOL}"; then
                VOL_UID="${SP_UID}"
                storpoolDetach "${VOL_UID}" "force" "${DST_HOST}" "" "${READONLY}"
                storpoolVolumeTag "${VOL_UID}" "diskid;${VM_TAG};vc-policy;qc" ";;;${DEFAULT_QOSCLASS}"
            fi
        fi
        _LOGMSG="CDROM image"
    else
        _LOGMSG="PERSISTENT_TYPE=IMMUTABLE image"
    fi
    splog "${_LOGMSG}"
    log "${_LOGMSG}"
    DELAY_DELETE=
    SP_VOL+="-${VM_ID}-${DISK_ID}"
    if kvGetUid "${SP_VOL}"; then
        VOL_UID="${SP_UID}"
        # For CDROM, we'll handle both snap types later in combined call
        storpoolDelete "${VOL_UID}" "force" "" "" "\"img\":\"${SP_VOL}\",\"type\":\"CDROM\",\"reason\":\"tm_delete\""
    fi
else # image persist
    if kvGetUid "${SP_VOL}"; then
        msg="Not CLONE ${DST_PATH} PERSISTENT ${SP_UID} (${SP_VOL})"
        log "${msg}"
        splog "${msg}"
        storpoolLocate "${SP_UID}"
        case "${X_FOUND_AS,,}" in
            snapshot)
                storpoolDetach "${SP_UID}" "force" "" "all" "${READONLY}" snapshot
                storpoolSnapshotTag "${SP_UID}" "diskid;${VM_TAG};vc-policy;qc;type" ";;;${DEFAULT_QOSCLASS};"
                ;;
            volume)
                storpoolDetach "${SP_UID}" "force" "" "all" "${READONLY}"
                storpoolVolumeTag "${SP_UID}" "diskid;${VM_TAG};vc-policy;qc;type" ";;;${DEFAULT_QOSCLASS};"
                storpoolVolumeFreeze "${SP_UID}" "volume"
                ;;
            *)
                splog "WARNING ${DST_PATH} not found ${SP_UID} (${SP_VOL})"
                ;;
        esac
    fi
fi

if boolTrue "VMSNAPSHOT_DELETE_ON_TERMINATE"; then
    if [[ ${LCM_STATE} -ne 15 ]]; then
        storpoolSnapshotsDelete "${SP_VOL}" "${VMSNAPSHOT_TAG}"
        # Check if we need to also delete regular snapshots
        if boolTrue "IMMUTABLE" "${IMMUTABLE}" && [[ "${TYPE}" == "CDROM" ]]; then
            # CDROM case: delete both regular "snap" and VM "ONESNAP" snapshots
            storpoolSnapshotsDelete "${SP_VOL}" "snap,${VMSNAPSHOT_TAG}"
        else
            # Other cases: only delete VM snapshots
            storpoolSnapshotsDelete "${SP_VOL}" "${VMSNAPSHOT_TAG}"
        fi
    else
        splog "VMSNAPSHOT(s) not deleted because LCM_STATE=${LCM_STATE} (${SP_VOL}-${VMSNAPSHOT_TAG}-*)"
    fi
else
    splog "skipped VMSNAPSHOT_DELETE_ON_TERMINATE"
fi

RM_CMD=$(cat <<EOF
if [[ -f "${DST_PATH}.monitor" ]]; then
  rm -f "${DST_PATH}.monitor"
fi
rm -f "${DST_PATH}"
EOF
)

if hostReachable "${DST_HOST}"; then
    splog "run RM_CMD on ${DST_HOST} (${DST_PATH})"
    ssh_exec_and_log "${DST_HOST}" "${RM_CMD}" \
              "Error deleting ${SP_VOL} in ${DST_HOST}(${DST_PATH})"
else
    splog "Host unreachable: ${DST_HOST}, skipping ${RM_CMD}"
fi

splog "END ${VM_ID}"
exit 0
