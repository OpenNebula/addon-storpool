#-------------------------------------------------------------------------------
# ln host:datastore/image host:remote_system_ds/disk.i vmId datastoreId
#-------------------------------------------------------------------------------

#-------------------------------------------------------------------------------
# Get ln arguments from OpenNebula core
#-------------------------------------------------------------------------------

SRC="$1"
DST="$2"
VM_ID="$3"
DS_ID="$4"

TM_PATH="$(dirname "$0")"
# shellcheck source=tm/storpool/storpool_common.sh
source "${TM_PATH}/storpool_common.sh"

splog "SRC=${SRC} DST=${DST} VM_ID=${VM_ID} DS_ID=${DS_ID}"

#-------------------------------------------------------------------------------
# Do nothing if src and dst are same
#-------------------------------------------------------------------------------

if [[ "{${SRC}" == "${DST}" ]]; then
    msg="Not moving ${SRC} to ${DST}, they are the same path"
    log "[I] ${msg}"
    splog "END ${VM_ID} ${msg}"
    exit 0
fi

log "${SRC} to disk ${DST} on VM ${VM_ID}"

#-------------------------------------------------------------------------------
# Process source and destination
#-------------------------------------------------------------------------------

DST_PATH=$(arg_path "${DST}")
DST_HOST=$(arg_host "${DST}")
# shellcheck disable=SC2016
DISK_ID="$(echo "${DST_PATH}" | ${AWK:-awk} -F. '{print $NF}')"

if boolTrue "MULTICLUSTER"; then
   oneHostInfo "${DST_HOST}"
   DO_REMOTE="~${HOST_SP_CLUSTER_ID}"
fi

#-------------------------------------------------------------------------------
# Get Image information
#-------------------------------------------------------------------------------

oneVmInfo "${VM_ID}" "${DISK_ID}"

if boolTrue "SHAREABLE"; then
    msg="[ERROR] Unsupported persistent image type"
    msg+=" (${SHAREABLE:+DISK/SHAREABLE=${SHAREABLE} }${PERSISTENT_TYPE:+PERSISTENT_TYPE=${PERSISTENT_TYPE}})."
    splog "${msg}"
    log_error "${msg}"
    exit 1
fi

IMMUTABLE="$(isImmutable "${CLONE}" "${SAVE}" "${READONLY}")"
if boolTrue "IMMUTABLE"; then
    if [[ "${TYPE^^}" != "CDROM" ]]; then
        msg="[ERROR] Unsupported persistent image type: IMMUTABLE"
        msg+=" (${PERSISTENT_TYPE:+PERSISTENT_TYPE=${PERSISTENT_TYPE}})."
        splog "${msg}"
        log_error "${msg}"
        exit 1
    fi
fi

#-------------------------------------------------------------------------------
# Get System Datastore information
#-------------------------------------------------------------------------------

oneDatastoreInfo "${VM_DS_ID}"
SYSTEM_DS_SP_QOSCLASS="${DS_SP_QOSCLASS}"

#-------------------------------------------------------------------------------
# Get Image Datastore information
#-------------------------------------------------------------------------------

oneDatastoreInfo "${DS_ID}"
IMAGE_DS_SP_QOSCLASS="${DS_SP_QOSCLASS}"

SP_VOL="${SOURCE##*/}"
kvGetUid "${SP_VOL}" fatal
SRC_UID="${SP_UID}"
if [[ "${TYPE}" == "CDROM" ]]; then
    CDROM_VOL="${SP_VOL}-${VM_ID}-${DISK_ID}"
    if ! kvGetUid "${CDROM_VOL}"; then
        storpoolVolumeFromSnapshot "${SRC_UID}" "${CDROM_VOL}"
    fi
    SP_VOL="${CDROM_VOL}"
else
    storpoolVolumeFromSnapshot "${SP_UID}" "${SP_VOL}"
    storpoolSnapshotDelete "${SRC_UID}" "1"
fi
VOL_UID="${SP_UID}"

if boolTrue "NO_VOLUME_TEMPLATE"; then
    SP_TEMPLATE=""
else
    SP_TEMPLATE="${ONE_PX}-ds-${DS_ID}"
fi

if [[ "${TYPE}" == "CDROM" ]]; then
    # omit IMAGE_SP_QOSCLASS
    IMAGE_SP_QOSCLASS=""
#    if [[ -n "${IMAGE_DS_SP_QOSCLASS}" ]]; then
#        # SP_QOSCLASS in the attributes of the IMAGE DS
#        # overrides the one in the SYSTEM DS
#        SYSTEM_DS_SP_QOSCLASS=""
#    fi
    IMAGE_DS_SP_QOSCLASS=""
fi
SP_QOSCLASS="${VM_DISK_SP_QOSCLASS:-${IMAGE_SP_QOSCLASS:-${VM_SP_QOSCLASS:-${SYSTEM_DS_SP_QOSCLASS:-${IMAGE_DS_SP_QOSCLASS:-${DEFAULT_QOSCLASS}}}}}}"
debug_sp_qosclass

splog "SRC_UID=${SRC_UID} VOL_UID=${VOL_UID} SP_VOL=${SP_VOL} SP_TEMPLATE=${SP_TEMPLATE}${SP_QOSCLASS:+ SP_QOSCLASS=${SP_QOSCLASS}}"

#-------------------------------------------------------------------------------
# Enable the destination device
#-------------------------------------------------------------------------------

if [[ -n "${SIZE}" ]]; then
    if [[ ${SIZE} -gt ${ORIGINAL_SIZE:-0} ]]; then
        if boolTrue "CLONE"; then
            storpoolVolumeResize "${VOL_UID}" "$((SIZE*1024*1024))"
        else
            splog "[I] not resizing Non-CLONED ${VOL_UID} (${SP_VOL}) SIZE=${SIZE} ORIGINAL_SIZE=${ORIGINAL_SIZE}"
        fi
    fi
fi
TAG_TYPE="PERS"
if boolTrue "READONLY"; then
    if [[ "${TYPE}" == "CDROM" ]]; then
        TAG_TYPE="CDROM"
    elif boolTrue "IMMUTABLE"; then
        TAG_TYPE="IMMUT"
        if boolTrue "CLONE"; then
            TAG_TYPE="CLONE"
        fi
    else
        TAG_TYPE+="RO"
    fi
    SP_MODE="${READONLY_MODE,,}"
fi

if kvGetUid "${SP_VOL}" fatal; then
    VOL_UID="${SP_UID}"
    storpoolAttach "${VOL_UID}" "${DST_HOST}" "${SP_MODE}" volume detachAll
    storpoolVolumeTag "${VOL_UID}" \
            "virt;${LOC_TAG};diskid;${VM_TAG};type;${VC_POLICY:+vc-policy};qc" \
            "one;${LOC_TAG_VAL};${DISK_ID};${VM_ID};${TAG_TYPE};${VC_POLICY};${SP_QOSCLASS}"
fi

#-------------------------------------------------------------------------------
# Get SYSTEM Datastore information
#-------------------------------------------------------------------------------

oneDatastoreInfo "${VM_DS_ID}"

MONITOR_TM_MAD=""
if ! boolTrue "DS_SHARED"; then
    MONITOR_TM_MAD="${DS_TM_MAD}"
fi

if [[ -n "${VOL_UID}" ]]; then
    oneSymlink "${DST_HOST}" "${VOL_UID}" "${DST_PATH}"
fi

if [[ -n "${SNAPSHOT_UID}" ]]; then
    DO_REMOTE="" storpoolSnapshotDelete "${SNAPSHOT_UID}" snapshotOnly
fi

splog "END ${VM_ID}"
exit 0
