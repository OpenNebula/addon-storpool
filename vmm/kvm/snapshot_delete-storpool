#-------------------------------------------------------------------------------
# snapshot_create  domain snap_id vm_id vmhost
#-------------------------------------------------------------------------------

#-------------------------------------------------------------------------------
# Get snapshot_create arguments from OpenNebula core
#-------------------------------------------------------------------------------

DOMAIN="$1"
SNAP_ID="$2"
VM_ID="$3"
VMHOST="$4"
export DOMAIN

DRIVER_PATH="$(dirname "$0")"
if [[ -f "${DRIVER_PATH}/../../etc/vmm/kvm/kvmrc" ]]; then
    # shellcheck source=/dev/null
    source "${DRIVER_PATH}/../../etc/vmm/kvm/kvmrc"
else
    # shellcheck source=/dev/null
    source "${DRIVER_PATH}/kvmrc"
fi
# shellcheck source=/dev/null
source "${DRIVER_PATH}/../../scripts_common.sh"
# shellcheck source=tm/storpool/storpool_common.sh
source "${DRIVER_PATH}/../../tm/storpool/storpool_common.sh"

export LOG_PREFIX="vmm"

if boolTrue "DEBUG_VMSNAPSHOT"; then
    splog "$0 ${DOMAIN} ${SNAP_ID} ${VM_ID} ${VMHOST}"
fi

if boolTrue "VMSNAPSHOT_OVERRIDE"; then
    oneVmVolumes "${VM_ID}"
    oneDatastoreInfo "${VM_DS_ID}"

    oneHostInfo "${VMHOST}"
    DO_REMOTE="~${HOST_SP_CLUSTER_ID}"

    declare -A diskVolumes
    for v in ${vmVolumes}; do
        diskVolumes["${v}"]="${v}"
    done
    if [[ -n "${TPM_MODEL}" ]]; then
        SWTPM_VOL="${ONE_PX}-sys-${VM_ID}-SWTPM"
        diskVolumes["${SWTPM_VOL}"]="${SWTPM_VOL}"
    fi
    if storpoolRetry SnapshotsList; then
        while read -r -u "${jqfh}" sp_uid img; do
            if boolTrue "DDEBUG_VMSNAPSHOT"; then
                splog "[DD] ${sp_uid} tags.img:${img}"
            fi
            if [[ -z ${diskVolumes["${img}"]} ]]; then
                if boolTrue "DEBUG_VMSNAPSHOT"; then
                    splog "[D] VM ${VM_ID} Skip ${snap} for ${img} (not in diskVolumes:${diskVolumes[*]})"
                fi
                continue
            fi
            DO_REMOTE="" DO_MULTICLUSTER=1 storpoolRetry SnapshotDelete "${sp_uid}" >/dev/null
            kvDel "${img}-${SNAP_ID}" "${sp_uid}"
        done {jqfh}< <(jq -r --arg snp "${SNAP_ID}" --arg vmtag "${VM_TAG}" --arg vmid "${VM_ID}" \
                    '.data[]|select(.tags[$vmtag]==$vmid)|select(.tags["snap"]==$snp)|select(.deleted==false)|.name+" "+.tags["img"]' \
                    "${TMPDIR}/SnapshotsList.json" || true)
        exec {jqfh}<&-
        splog "END VM_ID=${VM_ID} VMHOST=${VMHOST} SNAP_ID=${SNAP_ID}"
    else
        splog "END ($?) VM_ID=${VM_ID} VMHOST=${VMHOST} SNAP_ID=${SNAP_ID}"
    fi
fi
